      "cite": "user-stated"
    },
    {
      "id": "edge_16",
      "source": "az_fd",
      "target": "az_b2c",
      "label": "Direct client logins path",
      "cite": "user-stated"
    },
    {
      "id": "edge_17",
      "source": "az_cosmos",
      "target": "az_ai",
      "label": "Tracks query executions logs",
      "cite": "user-stated"
