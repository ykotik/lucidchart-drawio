{
  "pattern": "sequence",
  "canvas": {
    "w": 1600,
    "h": 900
  },
  "containers": [],
  "shapes": [
    {
      "id": "ll_browser",
      "label": "Browser",
      "cite": "user-stated"
    },
    {
      "id": "ll_apigw",
      "label": "API Gateway",
      "cite": "user-stated"
    },
    {
      "id": "ll_cart",
      "label": "Cart Service",
      "cite": "user-stated"
    },
    {
      "id": "ll_order",
      "label": "Order Service",
      "cite": "user-stated"
    },
    {
      "id": "ll_pay",
      "label": "Payment Service",
      "cite": "user-stated"
    },
    {
      "id": "ll_inv",
      "label": "Inventory Service",
      "cite": "user-stated"
    },
    {
      "id": "ll_notif",
      "label": "Notification Service",
      "cite": "user-stated"
    }
  ],
  "edges": [
    {
      "id": "edge_0",
      "source": "ll_browser",
      "target": "ll_apigw",
      "label": "POST /checkout",
      "cite": "user-stated"
    },
    {
      "id": "edge_1",
      "source": "ll_apigw",
      "target": "ll_cart",
      "label": "GET /cart/active",
      "cite": "user-stated"
    },
    {
      "id": "edge_2",
      "source": "ll_cart",
      "target": "ll_apigw",
      "label": "Cart data returned",
      "cite": "user-stated"
    },
    {
      "id": "edge_3",
      "source": "ll_apigw",
      "target": "ll_order",
      "label": "POST /order (create)",
      "cite": "user-stated"
    },
    {
      "id": "edge_4",
      "source": "ll_order",
      "target": "ll_inv",
      "label": "POST /inventory/reserve",
      "cite": "user-stated"
    },
    {
      "id": "edge_5",
      "source": "ll_inv",
      "target": "ll_order",
      "label": "Stock reserved (success)",
      "cite": "user-stated"
    },
    {
      "id": "edge_6",
      "source": "ll_order",
      "target": "ll_pay",
      "label": "POST /payment/charge",
      "cite": "user-stated"
    },
    {
      "id": "edge_7",
      "source": "ll_pay",
      "target": "ll_order",
      "label": "Charge successful (auth code)",
      "cite": "user-stated"
    },
    {
      "id": "edge_8",
      "source": "ll_order",
      "target": "ll_notif",
      "label": "POST /notify/order-created",
      "cite": "user-stated"
