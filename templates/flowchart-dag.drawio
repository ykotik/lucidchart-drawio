<mxfile host="lucidchart-drawio-skill" type="device">
  <diagram name="Flowchart" id="flow">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="edges" value="Edges" parent="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Flowchart (DAG) with Decision Diamonds" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1520" height="32" as="geometry"/>
        </mxCell>

        <mxCell id="start" value="Start" style="ellipse;whiteSpace=wrap;html=1;fillColor=#2E7D32;strokeColor=#1B5E20;fontColor=#FFFFFF;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="720" y="100" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="p1" value="Receive order" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontColor=#1565C0;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="700" y="210" width="160" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="d1" value="Stock&lt;br/&gt;available?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;fontColor=#F57F17;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="700" y="320" width="160" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="p2" value="Reserve stock" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontColor=#1565C0;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="940" y="340" width="160" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="p3" value="Notify customer:&lt;br/&gt;out of stock" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;fontColor=#C62828;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="460" y="340" width="160" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="d2" value="Payment&lt;br/&gt;captured?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;fontColor=#F57F17;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="940" y="450" width="160" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="p4" value="Ship order" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontColor=#1565C0;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="940" y="600" width="160" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="p5" value="Release stock,&lt;br/&gt;refund attempt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;fontColor=#C62828;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1180" y="470" width="180" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="end_ok" value="End (Fulfilled)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#2E7D32;strokeColor=#1B5E20;fontColor=#FFFFFF;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="960" y="720" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="end_oos" value="End (OOS)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#C62828;strokeColor=#8B1A1A;fontColor=#FFFFFF;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="480" y="450" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="end_failed" value="End (Pay Failed)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#C62828;strokeColor=#8B1A1A;fontColor=#FFFFFF;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1200" y="580" width="160" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="f1" style="endArrow=block;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#424242;" edge="1" parent="edges" source="start" target="p1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="f2" style="endArrow=block;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#424242;" edge="1" parent="edges" source="p1" target="d1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="f3" value="Yes" style="endArrow=block;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#2E7D32;fontColor=#2E7D32;fontSize=11;fontStyle=1;" edge="1" parent="edges" source="d1" target="p2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="f4" value="No" style="endArrow=block;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.5;entryX=1;entryY=0.5;strokeColor=#C62828;fontColor=#C62828;fontSize=11;fontStyle=1;" edge="1" parent="edges" source="d1" target="p3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="f5" style="endArrow=block;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#424242;" edge="1" parent="edges" source="p3" target="end_oos">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="f6" style="endArrow=block;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#424242;" edge="1" parent="edges" source="p2" target="d2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="f7" value="Yes" style="endArrow=block;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#2E7D32;fontColor=#2E7D32;fontSize=11;fontStyle=1;" edge="1" parent="edges" source="d2" target="p4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="f8" value="No" style="endArrow=block;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#C62828;fontColor=#C62828;fontSize=11;fontStyle=1;" edge="1" parent="edges" source="d2" target="p5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="f9" style="endArrow=block;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#424242;" edge="1" parent="edges" source="p4" target="end_ok">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="f10" style="endArrow=block;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#424242;" edge="1" parent="edges" source="p5" target="end_failed">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
